# Copy to .env and fill in. Leave blank to use the MVP mock behavior.

# Database (default: local SQLite). For Supabase/Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/tripstalker
DATABASE_URL=sqlite:///./tripstalker.db

# GlobalAdapter (Booking via RapidAPI). Blank => mock prices.
RAPIDAPI_KEY=
RAPIDAPI_HOST=booking-com.p.rapidapi.com

# Travelpayouts flight-data API (cheapest-flight-by-date on Travelist tracks).
# TOKEN from your Travelpayouts developer dashboard; MARKER is your affiliate id.
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# Unsplash destination photos (free key from unsplash.com/developers). Blank => no photo.
UNSPLASH_ACCESS_KEY=

# IsraelAdapter (Travelist). Residential proxy to bypass WAF (optional).
PROXY_URL=

# Notify when price drops at least this fraction below baseline (0.02 = 2%).
PRICE_DROP_THRESHOLD=0.02

# Allowed frontend origin for CORS (set to your Vercel web URL in prod).
FRONTEND_ORIGIN=http://localhost:5173

# Auth: secret used to sign JWT login tokens. MUST be set to a long random
# value in production (e.g. `openssl rand -hex 32`). Tokens are forgeable without it.
JWT_SECRET=dev-insecure-change-me
# Token lifetime in minutes (default 14 days).
JWT_EXPIRE_MINUTES=20160

# Shared secret for the /api/cron/check-prices endpoint. Vercel Cron sends it as
# "Authorization: Bearer <CRON_SECRET>". Leave blank locally to keep it open.
CRON_SECRET=

# Telegram price-drop alerts (free). Create a bot via @BotFather for the token,
# then message your bot and read chat.id from
# https://api.telegram.org/bot<TOKEN>/getUpdates . Blank => alerts just log.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
